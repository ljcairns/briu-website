{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://briu.ai/build/task-feed.schema.json",
  "title": "Briu Build Task Feed",
  "description": "Schema for a live task feed derived from dispatched_tasks plus completion-side enrichment from Paula dispatch results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "timezone",
    "window",
    "source",
    "workflow",
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string"
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "start",
        "end"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_table",
        "status_precedence",
        "completion_fields"
      ],
      "properties": {
        "primary_table": {
          "type": "string",
          "const": "dispatched_tasks"
        },
        "status_precedence": {
          "type": "string",
          "enum": [
            "observed_status_over_dispatch_status"
          ]
        },
        "completion_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "loop_note",
        "steps"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "loop_note": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "nullableDateTime": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableString": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableInteger": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableNumber": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "dispatchStatus": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "success",
        "partial",
        "failed",
        "timeout",
        "error"
      ]
    },
    "observedStatus": {
      "anyOf": [
        {
          "$ref": "#/$defs/dispatchStatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "syncState": {
      "type": "string",
      "enum": [
        "mirrored",
        "completion_only",
        "dispatch_only"
      ]
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actor",
        "label",
        "detail"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "title",
        "repo",
        "backend",
        "dispatch_status",
        "observed_status",
        "sync_state",
        "prompt_excerpt",
        "dispatched_at",
        "completed_at",
        "result_summary",
        "exit_code",
        "duration_seconds",
        "depends_on",
        "dispatch_after",
        "manifest_message_id",
        "timeout_seconds",
        "max_turns",
        "cost_usd",
        "commit_hash",
        "thread_ref",
        "requested_by",
        "assigned_to"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "backend": {
          "type": "string",
          "enum": [
            "claude",
            "codex",
            "exec"
          ]
        },
        "dispatch_status": {
          "$ref": "#/$defs/dispatchStatus"
        },
        "observed_status": {
          "$ref": "#/$defs/observedStatus"
        },
        "sync_state": {
          "$ref": "#/$defs/syncState"
        },
        "prompt_excerpt": {
          "type": "string"
        },
        "dispatched_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "result_summary": {
          "$ref": "#/$defs/nullableString"
        },
        "exit_code": {
          "$ref": "#/$defs/nullableInteger"
        },
        "duration_seconds": {
          "$ref": "#/$defs/nullableInteger"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dispatch_after": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "manifest_message_id": {
          "$ref": "#/$defs/nullableString"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "cost_usd": {
          "$ref": "#/$defs/nullableNumber"
        },
        "commit_hash": {
          "$ref": "#/$defs/nullableString"
        },
        "thread_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "requested_by": {
          "type": "string"
        },
        "assigned_to": {
          "type": "string"
        }
      }
    }
  }
}
